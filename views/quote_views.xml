<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wa_marketing_quote_tree" model="ir.ui.view">
        <field name="name">wa.marketing.quote.tree</field>
        <field name="model">wa.marketing.quote</field>
        <field name="arch" type="xml">
            <list>
                <field name="campaign_id"/>
                <field name="external_quote_id"/>
                <field name="amount"/>
                <field name="currency_code"/>
                <field name="status"/>
                <field name="expires_at"/>
            </list>
        </field>
    </record>

    <record id="action_wa_marketing_quote" model="ir.actions.act_window">
        <field name="name">Quotes</field>
        <field name="res_model">wa.marketing.quote</field>
        <field name="view_mode">list</field>
    </record>
</odoo>
