<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_wa_marketing_customer_profile_list" model="ir.ui.view">
        <field name="name">wa.marketing.customer.profile.list</field>
        <field name="model">wa.marketing.customer.profile</field>
        <field name="arch" type="xml">
            <list string="Customer Intelligence">
                <field name="partner_id"/>
                <field name="phone"/>
                <field name="total_orders"/>
                <field name="avg_order_value"/>
                <field name="favorite_item"/>
                <field name="preferred_day_of_week"/>
                <field name="preferred_hour"/>
                <field name="last_order_at"/>
                <field name="expected_next_order_at"/>
                <field name="churn_risk_score"/>
                <field name="churn_risk_level"/>
                <field name="last_profile_refresh_at"/>
            </list>
        </field>
    </record>

    <record id="view_wa_marketing_customer_profile_form" model="ir.ui.view">
        <field name="name">wa.marketing.customer.profile.form</field>
        <field name="model">wa.marketing.customer.profile</field>
        <field name="arch" type="xml">
            <form string="Customer Intelligence">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1"/>
                        </h1>
                    </div>

                    <group>
                        <group string="Customer">
                            <field name="partner_id"/>
                            <field name="phone"/>
                            <field name="mobile"/>
                            <field name="email"/>
                            <field name="active"/>
                        </group>

                        <group string="Churn Summary">
                            <field name="churn_risk_score"/>
                            <field name="churn_risk_level"/>
                            <field name="last_profile_refresh_at"/>
                        </group>
                    </group>

                    <group>
                        <group string="Order Behaviour">
                            <field name="total_orders"/>
                            <field name="avg_order_value"/>
                            <field name="avg_days_between_orders"/>
                            <field name="favorite_item"/>
                        </group>

                        <group string="Pattern">
                            <field name="preferred_day_of_week"/>
                            <field name="preferred_hour"/>
                            <field name="last_order_at"/>
                            <field name="expected_next_order_at"/>
                        </group>
                    </group>

                    <group string="Churn Reasoning">
                        <field name="churn_reason" nolabel="1"/>
                    </group>

                    <notebook>
                        <page string="Signals">
                            <field name="churn_signal_ids" readonly="1">
                                <list>
                                    <field name="created_at"/>
                                    <field name="signal_type"/>
                                    <field name="score"/>
                                    <field name="risk_level"/>
                                    <field name="expected_next_order_at"/>
                                    <field name="actual_last_order_at"/>
                                    <field name="is_active"/>
                                    <field name="reason"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_wa_marketing_customer_profile_search" model="ir.ui.view">
        <field name="name">wa.marketing.customer.profile.search</field>
        <field name="model">wa.marketing.customer.profile</field>
        <field name="arch" type="xml">
            <search string="Search Customer Intelligence">
                <field name="partner_id"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="favorite_item"/>
                <field name="churn_risk_level"/>

                <filter name="filter_high_risk" string="High Risk" domain="[('churn_risk_level', '=', 'high')]"/>
                <filter name="filter_medium_risk" string="Medium Risk" domain="[('churn_risk_level', '=', 'medium')]"/>
                <filter name="filter_low_risk" string="Low Risk" domain="[('churn_risk_level', '=', 'low')]"/>

                <separator/>

                <filter name="group_risk" string="Risk Level" context="{'group_by': 'churn_risk_level'}"/>
                <filter name="group_day" string="Preferred Day" context="{'group_by': 'preferred_day_of_week'}"/>
                <filter name="group_partner" string="Contact" context="{'group_by': 'partner_id'}"/>
            </search>
        </field>
    </record>

    <record id="action_wa_marketing_customer_profile" model="ir.actions.act_window">
        <field name="name">Customer Intelligence</field>
        <field name="res_model">wa.marketing.customer.profile</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>

</odoo>