<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_wa_campaign_settings" model="ir.ui.view">
        <field name="name">res.company.form.wa.campaign.settings</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="WA Campaign Settings" name="wa_campaign_settings">
                    <group>
                        <group string="Campaign Microservice">
                            <field name="wa_campaign_company_code"/>
                            <field name="wa_campaign_api_url" placeholder="http://optimum-muskrat-advanced.ngrok-free.app"/>
                            <field name="wa_campaign_api_token" password="True" placeholder="change-me"/>
                        </group>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="action_wa_campaign_settings" model="ir.actions.act_window">
        <field name="name">Settings</field>
        <field name="res_model">res.company</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>